{
  "private": true,
  "license": "UNLICENSED",
  "author": "Ross Hill <ross@rosshill.ca> (https://rosshill.ca)",
  "type": "module",
  "scripts": {
    "build": "wireit",
    "check": "npm run getIcons && svelte-check --tsconfig ./tsconfig.json",
    "checkNodeVersions": "wireit",
    "dev": "wireit",
    "getColourPaletteSwatches": "wireit",
    "format": "prettier --write  --plugin prettier-plugin-svelte .",
    "getGrain": "wireit",
    "getIcons": "wireit",
    "getWallpapers": "wireit",
    "getPosts": "wireit",
    "getWebp": "wireit",
    "optimizeImages": "wireit",
    "lint": "wireit",
    "lint:styles": "wireit",
    "lint:ts-svelte": "wireit",
    "prepare": "svelte-kit sync",
    "preview": "wireit",
    "test": "wireit",
    "upgrade": "ncu -u -x eslint,@typescript-eslint/parser,@typescript-eslint/eslint-plugin,eslint-plugin-unicorn,eslint-plugin-svelte && npm i --force"
  },
  "browserslist": "last 5 years or >0.2%",
  "devDependencies": {
    "@babel/core": "^7.29.0",
    "@babel/eslint-parser": "^7.28.6",
    "@iconify/json": "^2.2.478",
    "@playwright/test": "^1.60.0",
    "@sveltejs/adapter-node": "^5.5.4",
    "@sveltejs/kit": "^2.61.1",
    "@sveltejs/vite-plugin-svelte": "^7.1.2",
    "@types/apca-w3": "^0.1.3",
    "@types/chroma-js": "^3.1.2",
    "@types/cssnano": "^5.1.3",
    "@types/culori": "^4.0.1",
    "@types/dateformat": "^5.0.3",
    "@types/imagemin": "^9.0.1",
    "@types/imagemin-webp": "^7.0.3",
    "@types/lodash-es": "^4.17.12",
    "@typescript-eslint/eslint-plugin": "^7.8.0",
    "@typescript-eslint/parser": "^7.8.0",
    "apca-w3": "0.1.9",
    "autoprefixer": "^10.5.0",
    "chroma-js": "^3.2.0",
    "cssnano": "^8.0.1",
    "culori": "^4.0.2",
    "date-fns": "^4.3.0",
    "eslint": "^8.56.0",
    "eslint-config-airbnb-base": "^15.0.0",
    "eslint-config-airbnb-typescript": "^18.0.0",
    "eslint-config-prettier": "^10.1.8",
    "eslint-plugin-import": "^2.32.0",
    "eslint-plugin-prettier": "^5.5.5",
    "eslint-plugin-svelte": "^2.46.1",
    "eslint-plugin-unicorn": "^56.0.1",
    "imagemin": "^9.0.1",
    "imagemin-jpegtran": "^8.0.0",
    "imagemin-optipng": "^8.0.0",
    "imagemin-webp": "^8.0.0",
    "lodash-es": "^4.18.1",
    "markdown-json": "^1.6.1",
    "npm-check-updates": "^22.2.1",
    "postcss-html": "^1.8.1",
    "prettier": "^3.8.3",
    "prettier-plugin-svelte": "^4.0.1",
    "sass": "^1.100.0",
    "sharp": "^0.34.5",
    "simple-icons": "^16.21.0",
    "slugify": "^1.6.9",
    "stylelint": "^17.12.0",
    "stylelint-config-standard-scss": "^17.0.0",
    "svelte": "^5.55.9",
    "svelte-check": "^4.4.8",
    "svelte-meta-tags": "^4.7.0",
    "svelte-wrap-balancer": "^0.0.4",
    "tsx": "^4.22.3",
    "typescript": "^6.0.3",
    "universal-cookie": "^8.1.2",
    "unplugin-icons": "^23.0.1",
    "vite": "^8.0.14",
    "wireit": "^0.14.12",
    "xml-formatter": "^3.7.0"
  },
  "engines": {
    "node": ">= 20.19.0"
  },
  "wireit": {
    "build": {
      "command": "vite build",
      "dependencies": [
        "checkNodeVersions",
        "getColourPaletteSwatches",
        "getIcons",
        "optimizeImages"
      ],
      "files": [
        "tsconfig.json",
        "package.json",
        "package-lock.json",
        ".nvmrc",
        "svelte.config.js",
        "vite.config.ts",
        "src/**/*",
        "assets/**/*"
      ],
      "output": [
        "build"
      ]
    },
    "getIcons": {
      "command": "tsx ./scripts/getIcons.ts",
      "dependencies": [
        "getPosts"
      ],
      "files": [
        "tsconfig.json",
        "package.json",
        "package-lock.json",
        ".nvmrc",
        "data/posts.json",
        "scripts/designTokens.ts",
        "scripts/getIcons.ts"
      ],
      "output": [
        "data/tagColors.json",
        "assets/tags"
      ]
    },
    "getPosts": {
      "command": "markdown-json -c content/.mdconfig.json",
      "files": [
        "tsconfig.json",
        "package.json",
        "package-lock.json",
        ".nvmrc",
        "content/**/*"
      ],
      "output": [
        "data/posts.json"
      ]
    },
    "getWebp": {
      "command": "tsx ./scripts/getWebp.ts",
      "files": [
        "tsconfig.json",
        "package.json",
        "package-lock.json",
        ".nvmrc",
        "assets/**/*.{png,jpg,jpeg}",
        "scripts/getWebp.ts"
      ],
      "output": [
        "assets/**/*.webp"
      ]
    },
    "getGrain": {
      "command": "tsx ./scripts/getGrain.ts",
      "files": [
        "tsconfig.json",
        "package.json",
        "package-lock.json",
        ".nvmrc",
        "src/lib/styles/design-system.scss",
        "scripts/designTokens.ts",
        "scripts/getGrain.ts"
      ],
      "output": [
        "assets/background-grain-dark.png"
      ]
    },
    "getWallpapers": {
      "command": "tsx ./scripts/getWallpapers.ts",
      "files": [
        "tsconfig.json",
        "package.json",
        "package-lock.json",
        ".nvmrc",
        "src/lib/styles/design-system.scss",
        "src/lib/components/sidebar/Sidebar.svelte",
        "assets/leaves-mask.png",
        "scripts/designTokens.ts",
        "scripts/getWallpapers.ts"
      ],
      "output": [
        "assets/linkedin-wallpaper-light.png",
        "assets/linkedin-wallpaper-dark.png",
        "assets/og-background-dark.png"
      ]
    },
    "getColourPaletteSwatches": {
      "command": "tsx ./scripts/getColourPaletteSwatches.ts",
      "files": [
        "tsconfig.json",
        "package.json",
        "package-lock.json",
        ".nvmrc",
        "src/lib/styles/design-system.scss",
        "scripts/designTokens.ts",
        "scripts/getColourPaletteSwatches.ts"
      ],
      "output": [
        "assets/colour-palette-swatches.svg"
      ]
    },
    "optimizeImages": {
      "command": "tsx ./scripts/optimizeImages.ts",
      "dependencies": [
        "getWebp",
        "getGrain",
        "getWallpapers"
      ],
      "files": [
        "tsconfig.json",
        "package.json",
        "package-lock.json",
        ".nvmrc",
        "assets/**/*.{png,jpg,jpeg,webp}",
        "scripts/optimizeImages.ts",
        "scripts/imagemin-plugins.d.ts"
      ],
      "output": [
        "assets/**/*.{png,jpg,jpeg,webp}"
      ],
      "clean": false
    },
    "checkNodeVersions": {
      "command": "tsx ./scripts/checkNodeVersions.ts",
      "files": [
        "tsconfig.json",
        "package.json",
        "package-lock.json",
        ".nvmrc",
        "scripts/checkNodeVersions.ts"
      ],
      "output": []
    },
    "lint": {
      "dependencies": [
        "lint:ts-svelte",
        "lint:styles"
      ]
    },
    "lint:styles": {
      "command": "stylelint \"**/*.{css,scss,svelte}\" --ignore-path .gitignore",
      "files": [
        "tsconfig.json",
        "package.json",
        "package-lock.json",
        ".nvmrc",
        "**/*.{css,scss,svelte}",
        ".stylelintrc.json"
      ],
      "output": []
    },
    "lint:ts-svelte": {
      "command": "eslint \"**/*.{js,ts,svelte}\" --ignore-path .gitignore",
      "files": [
        "tsconfig.json",
        "package.json",
        "package-lock.json",
        ".nvmrc",
        "src/**/*.{js,ts,svelte}",
        "scripts/**/*.{js,ts,svelte}",
        "svelte.config.js",
        "vite.config.ts",
        ".eslintrc.yml"
      ],
      "output": []
    },
    "test": {
      "command": "playwright test",
      "dependencies": [
        "build"
      ],
      "output": []
    },
    "dev": {
      "command": "vite dev --port 3000",
      "dependencies": [
        "build"
      ],
      "output": []
    },
    "preview": {
      "command": "vite preview --port 3000",
      "dependencies": [
        "build"
      ],
      "output": []
    }
  },
  "dependencies": {
    "@resvg/resvg-js": "^2.6.2",
    "satori": "^0.26.0",
    "tippy.js": "^6.3.7"
  }
}
